# Copy to backend/.env and fill in real values. NEVER commit the real .env.
# When running via docker compose, these are supplied by docker-compose.yml instead.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origins allowed to call the API (the Angular app)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
# Needed in production for HTTPS form/admin posts, e.g. https://rieakane.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# PostgreSQL — when POSTGRES_DB is set the app uses Postgres (else SQLite).
POSTGRES_DB=rieakane
POSTGRES_USER=rieakane
POSTGRES_PASSWORD=rieakane
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
