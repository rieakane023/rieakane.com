# Copy to backend/.env and fill in real values. NEVER commit the real .env.
# When running via docker compose, these are supplied by docker-compose.yml instead.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Origins allowed to call the API (public frontend :4200, admin app :4300)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:4300,http://127.0.0.1:4300
# Needed in production for HTTPS form/admin posts, e.g. https://rieakane.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# Admin hardening (security.md). Use a non-guessable Django admin path in prod.
DJANGO_ADMIN_URL=control-panel/
# Require MFA at admin login. Defaults to ON whenever DEBUG is False.
DJANGO_REQUIRE_MFA=False
# Apps whose models are recorded in the audit trail.
DJANGO_AUDIT_TRACKED_APPS=accounts,api

# Database resolution order: DATABASE_URL → POSTGRES_* → SQLite.
# Managed Postgres on a host (Render/Supabase) — single connection string.
# Use the Supabase POOLED connstring (port 6543) for the app runtime.
# DATABASE_URL=postgresql://user:pass@host:6543/postgres

# PostgreSQL discrete vars — used by local docker compose when DATABASE_URL unset.
POSTGRES_DB=rieakane
POSTGRES_USER=rieakane
POSTGRES_PASSWORD=rieakane
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
